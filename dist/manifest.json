{
  "manifest_version": 3,
  "name": "Throughline Prototype",
  "version": "0.1.0",
  "description": "A local-first, source-linked outline side panel for loaded ChatGPT conversations.",
  "permissions": [
    "storage",
    "sidePanel",
    "activeTab"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "background": {
    "service_worker": "assets/service-worker.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open Throughline"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "assets/content-script.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
